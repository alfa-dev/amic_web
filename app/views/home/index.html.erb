<script type="module">
  import { initFace, setExpression, setActivity, playExpression,
           setDeviceOrientation, triggerShakeFX, getTouchZone,
           setSkin, listSkins }                                   from '/js/face.js';
  import { analyzeFrame, findBestMatch }                          from '/js/vision.js';
  import { initRobot, handleUserMessage, getRobot, setRobot,
           getCodeLibrary, resetCodeLibrary, isSleeping, wakeUp,
           getRobotStage }                                         from '/js/robot.js';
  import { listen, listenPTT, speak, getAvailableVoices }         from '/js/voice.js';
  import { initMemory, loadMemory, saveMemory, resetMemory }       from '/js/memory.js';
  import { preloadCodeLibrary }                                    from '/js/sandbox.js';
  import { getEmotionState, applyEvent }                           from '/js/emotion.js';
  import { createSession, saveMessage, updateSession }             from '/js/rails_api.js';
  import { getLogs, clearLogs }                                    from '/js/logger.js';

  const canvas      = document.getElementById('bip-face');
  const micBtn      = document.getElementById('mic-btn');
  const statusLabel = document.getElementById('status-label');
  const emotionLabel= document.getElementById('emotion-label');
  const pointsLabel = document.getElementById('points-label');
  const transcriptEl= document.getElementById('transcript');
  const responseEl  = document.getElementById('response');
  const textInput   = document.getElementById('text-input');
  const debugBtn    = document.getElementById('debug-btn');
  const debugPanel  = document.getElementById('debug-panel');
  const debugClose  = document.getElementById('debug-close');
  const sleepFx     = document.getElementById('sleep-fx');

  function getVoiceOptions() {
    const mem = loadMemory();
    return {
      voiceName:          mem.voiceName || '',
      rate:               parseFloat(mem.voiceRate) || 1,
      lang:               mem.voiceLang || 'pt-BR',
      elevenLabsApiKey:   mem.elevenLabsApiKey  || '',
      elevenLabsVoiceId:  mem.elevenLabsVoiceId || '',
      usePiperTts:        !!mem.usePiperTts,
      piperVoice:         mem.piperVoice || 'pt_BR-faber-medium',
    };
  }

  const emotionColors = {
    EUPHORIC:'#f5c842', HAPPY:'#7c6af5', NEUTRAL:'#555566',
    SAD:'#5588bb', GRUMPY:'#bb5555', TIRED:'#889988', EXHAUSTED:'#667766'
  };

  function updateUI(robot) {
    const state = getEmotionState(robot.emotionPoints, robot.stamina ?? 100);
    emotionLabel.textContent  = state.name;
    emotionLabel.className    = `emotion-label emotion-${state.key.toLowerCase()}`;
    const ef = document.getElementById('hud-emotion-fill');
    const sf = document.getElementById('hud-stamina-fill');
    ef.style.width      = (robot.emotionPoints ?? 50) + '%';
    ef.style.background = emotionColors[state.key] || '#555566';
    const s = robot.stamina ?? 100;
    sf.style.width      = s + '%';
    sf.style.background = s > 60 ? '#44aa66' : s > 30 ? '#aaaa44' : '#aa4444';
    const mem = loadMemory();
    if (mem.showDebug) {
      const lt = robot.memory?.long_term?.length ?? 0;
      const mt = robot.memory?.medium_term?.length ?? 0;
      const st = robot.memory?.short_term?.length ?? 0;
      pointsLabel.textContent = `emo:${robot.emotionPoints} stm:${robot.stamina??100} mem:${lt}L${mt}M${st}S`;
      pointsLabel.style.display = 'block';
    } else {
      pointsLabel.style.display = 'none';
    }
    updateDebugPanel();
  }

  // Load state from server (migrates localStorage data on first run)
  const { codeLibrary: savedLib } = await initMemory();
  if (savedLib) preloadCodeLibrary(savedLib);

  requestAnimationFrame(() => initFace(canvas, loadMemory().skinId || 'classic'));
  initRobot(canvas, updateUI);
  updateUI(getRobot());
  const robot = getRobot();
  document.getElementById('robot-name').textContent = robot.name || 'Amic';
  document.title = robot.name || 'Amic';

  // ── Onboarding ────────────────────────────────────────────────────────────────
  const obOverlay    = document.getElementById('onboarding');
  const obBubble     = document.getElementById('ob-bubble');
  const obNameForm   = document.getElementById('ob-name-form');
  const obNameInput  = document.getElementById('ob-name-input');
  const obConfirmBtn = document.getElementById('ob-confirm-btn');
  const obSkipBtn    = document.getElementById('ob-skip');

  async function _obFinish(ownerName) {
    const mem = loadMemory();
    if (ownerName) {
      mem.ownerName = ownerName;
      // Save as a long-term fact immediately
      mem.memory.long_term = [
        { content: `Meu criador se chama ${ownerName}`, importance: 4, last_used: 0 },
        ...mem.memory.long_term,
      ].slice(0, 80);
    }
    mem.onboardingDone = true;
    saveMemory(mem);
    obOverlay.classList.add('hidden');
    setTimeout(() => obOverlay.classList.add('gone'), 700);
  }

  if (!loadMemory().onboardingDone) {
    obOverlay.classList.remove('gone');
    // Step 1: sleeping → surprised → curious
    setExpression(canvas, 'SLEEPING', false);
    obBubble.textContent = 'zzzZZZ...';
    await new Promise(r => setTimeout(r, 1200));
    setExpression(canvas, 'SURPRISED', false);
    obBubble.textContent = '!';
    await new Promise(r => setTimeout(r, 700));
    setExpression(canvas, 'CURIOUS', false);
    // Step 2: ask who made them
    obBubble.textContent = 'oi... você é quem me fez?';
    await new Promise(r => setTimeout(r, 1500));
    obBubble.textContent = 'como você se chama?';
    obNameForm.classList.add('show');
    obNameInput.focus();

    const _doConfirm = async () => {
      const name = obNameInput.value.trim();
      if (!name) return;
      obNameForm.classList.remove('show');
      obBubble.textContent = `que nome bonito, ${name}! vou lembrar de você para sempre.`;
      setExpression(canvas, 'DELIGHTED', false);
      await speak(`que nome bonito, ${name}! vou lembrar de você para sempre.`, {
        ...getVoiceOptions(), emotionKey: 'DELIGHTED',
      });
      await new Promise(r => setTimeout(r, 700));
      obBubble.textContent = 'você pode me ouvir pelo microfone 🎤, me ver pela câmera 📷, e me tocar na tela.';
      await new Promise(r => setTimeout(r, 3500));
      await _obFinish(name);
    };
    obConfirmBtn.addEventListener('click', _doConfirm);
    obNameInput.addEventListener('keydown', e => { if (e.key === 'Enter') _doConfirm(); });
    obSkipBtn.addEventListener('click', () => _obFinish(''));
  }

  // Rails session
  let railsSessionId = sessionStorage.getItem('amic_session_id');
  if (!railsSessionId) {
    createSession(robot.name || 'Amic', robot.emotionPoints, robot.stamina ?? 100)
      .then(id => { railsSessionId = id; sessionStorage.setItem('amic_session_id', id); })
      .catch(() => {});
  }
  window.addEventListener('beforeunload', () => {
    if (!railsSessionId) return;
    const r = getRobot();
    updateSession(railsSessionId, r.emotionPoints, r.stamina ?? 100).catch(() => {});
  });

  // ── Audio context ─────────────────────────────────────────────────────────────
  let _audioCtx = null;
  function _getAudioCtx() {
    if (!_audioCtx) _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    // iOS suspends AudioContext until a user gesture — resume on every use
    if (_audioCtx.state === 'suspended') _audioCtx.resume().catch(() => {});
    return _audioCtx;
  }

  function _playRobotBleep() {
    try {
      const ctx = _getAudioCtx();
      const osc = ctx.createOscillator(), gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.frequency.value = 180 + Math.random() * 120;
      osc.type = 'sine';
      gain.gain.setValueAtTime(0, ctx.currentTime);
      gain.gain.linearRampToValueAtTime(0.035, ctx.currentTime + 0.08);
      gain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.45);
      osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.5);
    } catch {}
  }

  // Touch sounds
  function _tone(type, freq, freqEnd, dur, vol, startDelay = 0) {
    try {
      const ctx = _getAudioCtx();
      const now = ctx.currentTime + startDelay;
      const osc = ctx.createOscillator(), gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.type = type; osc.frequency.setValueAtTime(freq, now);
      if (freqEnd) osc.frequency.exponentialRampToValueAtTime(freqEnd, now + dur * 0.9);
      gain.gain.setValueAtTime(0, now);
      gain.gain.linearRampToValueAtTime(vol, now + Math.min(0.02, dur * 0.15));
      gain.gain.linearRampToValueAtTime(0, now + dur);
      osc.start(now); osc.stop(now + dur + 0.01);
    } catch {}
  }

  function _playTouchSound(type) {
    switch (type) {
      case 'bonk':
        _tone('triangle', 280, 90, 0.22, 0.06);
        break;
      case 'purr': {
        // Warm pleasant low hum (head pet)
        const freqs = [220, 277, 330];
        freqs.forEach((f, i) => _tone('sine', f, f * 1.05, 0.35, 0.025, i * 0.04));
        break;
      }
      case 'warm':
        // Gentle warm tone (cheek)
        _tone('sine', 440, 494, 0.28, 0.038);
        break;
      case 'hm':
        _tone('sine', 340, 320, 0.28, 0.032);
        break;
      case 'beep':
        _tone('sine', 660, null, 0.14, 0.042);
        break;
      case 'tickle': {
        // Rapid random bleeps
        for (let i = 0; i < 5; i++) {
          _tone('square', 300 + Math.random() * 380, null, 0.04, 0.022, i * 0.055);
        }
        break;
      }
      case 'blink_ow':
        // Quick descending "ow" — eyes poked
        _tone('triangle', 520, 160, 0.18, 0.055);
        break;
      case 'mphf':
        // Muffled thud — mouth touched
        _tone('sine', 180, 120, 0.20, 0.05);
        _tone('sawtooth', 190, 110, 0.18, 0.015);
        break;
      case 'annoyed':
        // Dissonant buzz — too many touches
        _tone('sawtooth', 180, 160, 0.30, 0.04);
        _tone('square',   185, 165, 0.30, 0.025);
        break;
      case 'grumpy':
        // Harsh descending complaint — very annoyed
        _tone('sawtooth', 220, 80, 0.45, 0.055);
        _tone('square',   110, 55, 0.40, 0.030);
        break;
      case 'shake':
        _tone('sawtooth', 200, 50, 0.45, 0.05);
        break;
    }
  }

  // Touch ripple visual
  function _spawnRipple(x, y) {
    const el = document.createElement('div');
    el.className = 'touch-ripple';
    el.style.left = x + 'px';
    el.style.top  = y + 'px';
    document.body.appendChild(el);
    el.addEventListener('animationend', () => el.remove());
  }

  // ── Touch irritation system ───────────────────────────────────────────────────
  // Per-zone hit count + global recent count, both decay over time.
  const _zoneHits = { eyes:0, mouth:0, head_top:0, cheek:0, neck:0, chest:0, face:0 };
  let _totalHits  = 0;

  setInterval(() => {
    for (const k in _zoneHits) _zoneHits[k] = Math.max(0, _zoneHits[k] - 0.7);
    _totalHits = Math.max(0, _totalHits - 0.5);
  }, 2500);

  // ── Touch / Click interaction on canvas ───────────────────────────────────────
  let _lastTouchTime = 0;

  function _handleTouchAt(clientX, clientY) {
    const zone = getTouchZone(clientX, clientY);

    // Hard rule: lower body → absolutely no reaction
    if (!zone || zone === 'lower_body') return;

    _spawnRipple(clientX, clientY);
    _zoneHits[zone] = (_zoneHits[zone] || 0) + 1;
    _totalHits++;
    const zc = _zoneHits[zone];

    const veryAnnoyed = _totalHits > 18;
    const annoyed     = _totalHits > 10;

    // Global saturation override
    if (veryAnnoyed) {
      playExpression('GRUMPY'); _playTouchSound('grumpy');
      setRobot(applyEvent(getRobot(), 'annoyed_touch'));
      return;
    }
    if (annoyed && zone !== 'head_top') {
      playExpression('WORRIED'); _playTouchSound('annoyed');
      setRobot(applyEvent(getRobot(), 'poked'));
      return;
    }

    switch (zone) {
      case 'head_top':
        // Petting — pleasant until too much
        if (zc <= 5) {
          playExpression('HAPPY'); _playTouchSound('purr');
          setRobot(applyEvent(getRobot(), 'petted'));
        } else {
          playExpression('SURPRISED'); _playTouchSound('bonk');
          setRobot(applyEvent(getRobot(), 'poked'));
        }
        break;

      case 'eyes':
        // Always uncomfortable — eyes are sensitive
        playExpression('SURPRISED'); _playTouchSound('blink_ow'); triggerShakeFX(0.35);
        setRobot(applyEvent(getRobot(), 'poked'));
        break;

      case 'mouth':
        // Uncomfortable — invaded personal space
        playExpression('CONFUSED'); _playTouchSound('mphf');
        setRobot(applyEvent(getRobot(), 'poked'));
        break;

      case 'cheek':
        // Pleasant in moderation
        if (zc <= 2) {
          playExpression('HAPPY'); _playTouchSound('warm');
          setRobot(applyEvent(getRobot(), 'petted'));
        } else if (zc <= 4) {
          playExpression('NEUTRAL'); _playTouchSound('hm');
        } else {
          playExpression('GRUMPY'); _playTouchSound('annoyed');
          setRobot(applyEvent(getRobot(), 'poked'));
        }
        break;

      case 'neck':
        // Ticklish — fun at first, irritating with excess
        if (zc <= 2) {
          playExpression('LAUGHING'); _playTouchSound('tickle');
          setRobot(applyEvent(getRobot(), 'tickled'));
        } else if (zc <= 5) {
          playExpression('WORRIED'); _playTouchSound('tickle');
        } else {
          playExpression('GRUMPY'); _playTouchSound('annoyed');
          setRobot(applyEvent(getRobot(), 'poked'));
        }
        break;

      case 'chest':
        playExpression(Math.random() < 0.5 ? 'HAPPY' : 'CURIOUS'); _playTouchSound('beep');
        break;

      case 'face':
        playExpression('CURIOUS'); _playTouchSound('hm');
        break;
    }
  }

  canvas.addEventListener('touchstart', e => {
    // iOS permission request on first touch
    _requestMotionPermission();
    const t = e.touches[0];
    const now = Date.now();
    if (now - _lastTouchTime < 800) return; // debounce
    _lastTouchTime = now;
    _handleTouchAt(t.clientX, t.clientY);
  }, { passive: true });

  canvas.addEventListener('mousedown', e => {
    // Only react to clicks that aren't on UI elements
    if (e.target !== canvas) return;
    const now = Date.now();
    if (now - _lastTouchTime < 200) return;
    _lastTouchTime = now;
    _handleTouchAt(e.clientX, e.clientY);
  });

  // ── Device orientation (tilt) ─────────────────────────────────────────────────
  let _motionSetup = false;
  function _setupDeviceListeners() {
    if (_motionSetup) return;
    _motionSetup = true;

    window.addEventListener('deviceorientation', e => {
      setDeviceOrientation(e.beta, e.gamma);
    });

    // Shake detection
    let _lastAccel = { x: 0, y: 0, z: 0 };
    let _shakeWindow = 0;
    let _shakePeaks  = 0;
    let _shakeCount  = 0;
    let _lastShakeAt = 0;

    window.addEventListener('devicemotion', e => {
      const a = e.accelerationIncludingGravity;
      if (!a) return;
      const dx = Math.abs(a.x - _lastAccel.x);
      const dy = Math.abs(a.y - _lastAccel.y);
      const dz = Math.abs(a.z - _lastAccel.z);
      _lastAccel = { x: a.x, y: a.y, z: a.z };
      const now = Date.now();
      if (dx + dy + dz > 18 && now - _lastShakeAt > 120) {
        _lastShakeAt = now;
        _shakePeaks++;
        if (_shakePeaks >= 3) {
          _shakePeaks = 0;
          _handleShake();
        }
      }
      // Reset peak counter if too much time passes
      if (now - _shakeWindow > 800) {
        _shakePeaks  = 0;
        _shakeWindow = now;
      }
    });
  }

  async function _requestMotionPermission() {
    if (_motionSetup) return;
    if (typeof DeviceOrientationEvent?.requestPermission !== 'function') {
      _setupDeviceListeners();
      return;
    }
    try {
      const p = await DeviceOrientationEvent.requestPermission();
      if (p === 'granted') _setupDeviceListeners();
    } catch {}
  }

  // On desktop, just set up listeners immediately
  if (typeof DeviceOrientationEvent?.requestPermission !== 'function') {
    _setupDeviceListeners();
  }

  // ── Shake reaction ────────────────────────────────────────────────────────────
  let _shakeReactionIndex = 0;
  const _shakeExpressions = ['SURPRISED', 'WORRIED', 'CONFUSED', 'EXCITED'];
  function _handleShake() {
    const expr = _shakeExpressions[_shakeReactionIndex % _shakeExpressions.length];
    _shakeReactionIndex++;
    triggerShakeFX(1.2 + Math.random() * 0.6);
    playExpression(expr);
    _playTouchSound('shake');
  }

  // ── Mic ───────────────────────────────────────────────────────────────────────
  let listening = false;
  micBtn.addEventListener('click', async () => {
    if (isSleeping()) { wakeUp(); return; }
    if (listening) return;
    listening = true;
    if (!loadMemory().apiKey) {
      statusLabel.textContent = 'Configure a chave da API primeiro (⚙)';
      setTimeout(() => (statusLabel.textContent = ''), 3000);
      listening = false;
      return;
    }
    micBtn.classList.add('listening');
    statusLabel.textContent = 'Ouvindo...';
    transcriptEl.textContent = '';
    responseEl.textContent = '';
    setActivity('listen');
    const mem = loadMemory();
    let text;
    try { text = await listen(mem.voiceLang || 'pt-BR'); }
    catch {
      statusLabel.textContent = 'Não consegui ouvir. Tente de novo.';
      micBtn.classList.remove('listening');
      setActivity('idle');
      setTimeout(() => (statusLabel.textContent = ''), 3000);
      listening = false;
      return;
    }
    micBtn.classList.remove('listening');
    transcriptEl.textContent = `Você: ${text}`;

    // If Amic is waiting for someone's name, intercept mic input
    if (_awaitingFaceName) {
      statusLabel.textContent = '';
      listening = false;
      await _saveNewFace(text);
      return;
    }

    statusLabel.textContent = 'Pensando...';
    setActivity('think');
    const r = getRobot();
    if (railsSessionId) saveMessage(railsSessionId, 'user', text, r.emotionPoints, r.stamina ?? 100).catch(() => {});
    const result = await handleUserMessage(text, {
      ...getVoiceOptions(),
      onChunk: (partial) => { responseEl.textContent = `Amic: ${partial}`; setActivity('speak'); },
      onEnd: () => setActivity('idle'),
    });
    if (result?.spokenText) {
      responseEl.textContent = `Amic: ${result.spokenText}`;
      if (railsSessionId) {
        const r2 = getRobot();
        saveMessage(railsSessionId, 'assistant', result.spokenText, r2.emotionPoints, r2.stamina ?? 100).catch(() => {});
      }
    } else if (result?.error) {
      responseEl.textContent = result.error;
      setActivity('idle');
    }
    statusLabel.textContent = '';
    listening = false;
  });

  // ── Text input (fallback when voice recognition isn't available) ──────────────
  textInput.addEventListener('keydown', async (e) => {
    if (e.key !== 'Enter') return;
    const text = textInput.value.trim();
    if (!text || listening) return;
    if (isSleeping()) { wakeUp(); return; }
    if (!loadMemory().apiKey) {
      statusLabel.textContent = 'Configure a chave da API primeiro (⚙)';
      setTimeout(() => (statusLabel.textContent = ''), 3000);
      return;
    }
    listening = true;
    textInput.value = '';
    textInput.disabled = true;
    transcriptEl.textContent = `Você: ${text}`;
    responseEl.textContent = '';

    if (_awaitingFaceName) {
      textInput.disabled = false;
      listening = false;
      await _saveNewFace(text);
      return;
    }

    statusLabel.textContent = 'Pensando...';
    setActivity('think');
    const r = getRobot();
    if (railsSessionId) saveMessage(railsSessionId, 'user', text, r.emotionPoints, r.stamina ?? 100).catch(() => {});
    const result = await handleUserMessage(text, {
      ...getVoiceOptions(),
      onChunk: (partial) => { responseEl.textContent = `Amic: ${partial}`; setActivity('speak'); },
      onEnd: () => setActivity('idle'),
    });
    if (result?.spokenText) {
      responseEl.textContent = `Amic: ${result.spokenText}`;
      if (railsSessionId) {
        const r2 = getRobot();
        saveMessage(railsSessionId, 'assistant', result.spokenText, r2.emotionPoints, r2.stamina ?? 100).catch(() => {});
      }
    } else if (result?.error) {
      responseEl.textContent = result.error;
      setActivity('idle');
    }
    statusLabel.textContent = '';
    textInput.disabled = false;
    textInput.focus();
    listening = false;
  });

  // ── Sleep effects ─────────────────────────────────────────────────────────────
  let _sleepFxTimer = null;
  const SLEEP_EMOJIS = ['💤', '⭐', '🌙', '💭', '✨', '🌟', '☁️', '🌠'];

  function _spawnZzzParticle() {
    const rect = canvas.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top  + rect.height * 0.28;
    const el = document.createElement('div');
    el.className = 'zzz-particle';
    const letters = ['Z','z','Z','zz','Zzz'];
    el.textContent = letters[Math.floor(Math.random() * letters.length)];
    const size = 0.65 + Math.random() * 0.75;
    el.style.fontSize = `${size}rem`;
    el.style.left = `${cx + (Math.random()-0.5)*64}px`;
    el.style.top  = `${cy + (Math.random()-0.5)*28}px`;
    el.style.setProperty('--dur', `${2.2+Math.random()*1.6}s`);
    sleepFx.appendChild(el);
    el.addEventListener('animationend', () => el.remove());
  }

  function _spawnDreamBubble(emoji) {
    const rect = canvas.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top  + rect.height * 0.22;
    const el = document.createElement('div');
    el.className = 'dream-bubble';
    el.textContent = emoji;
    el.style.left = `${cx + (Math.random()-0.5)*110-23}px`;
    el.style.top  = `${cy + (Math.random()-0.5)*44}px`;
    el.style.setProperty('--dur', `${3.8+Math.random()*2}s`);
    sleepFx.appendChild(el);
    el.addEventListener('animationend', () => el.remove());
  }

  function startSleepEffects() {
    let nextZ = 0, nextBleep = 0, nextEmoji = 0;
    _sleepFxTimer = setInterval(() => {
      const now = Date.now();
      if (now > nextZ)     { _spawnZzzParticle(); nextZ = now + 1100 + Math.random()*1200; }
      if (now > nextEmoji) { _spawnDreamBubble(SLEEP_EMOJIS[Math.floor(Math.random()*SLEEP_EMOJIS.length)]); nextEmoji = now + 3500 + Math.random()*3000; }
      if (now > nextBleep) { _playRobotBleep(); nextBleep = now + 3200 + Math.random()*4500; }
    }, 250);
  }
  function stopSleepEffects() {
    if (_sleepFxTimer) { clearInterval(_sleepFxTimer); _sleepFxTimer = null; }
    sleepFx.innerHTML = '';
  }

  document.addEventListener('amic:sleep', ({ detail }) => {
    if (detail.sleeping) {
      startSleepEffects();
      statusLabel.textContent = 'ZZZzzz...';
      transcriptEl.textContent = '';
      responseEl.textContent = '';
    } else {
      stopSleepEffects();
      statusLabel.textContent = '';
    }
  });

  document.addEventListener('amic:spontaneous', async ({ detail }) => {
    if (!detail.text || listening) return;
    transcriptEl.textContent = '';
    responseEl.textContent = `Amic: ${detail.text}`;
    setActivity('speak');
    await speak(detail.text, {
      ...getVoiceOptions(),
      emotionKey: detail.expressionKey || '',
      onEnd: () => { setActivity('idle'); responseEl.textContent = ''; },
    });
  });

  document.addEventListener('amic:dream', async ({ detail }) => {
    if (!detail.text || listening) return;
    const emojis = detail.dreamEmojis || [];
    if (emojis.length) {
      emojis.forEach((emoji, i) => setTimeout(() => _spawnDreamBubble(emoji), i * 380));
      await new Promise(r => setTimeout(r, 1400));
    }
    transcriptEl.textContent = '';
    responseEl.textContent = `Amic: ${detail.text}`;
    setActivity('speak');
    await speak(detail.text, {
      ...getVoiceOptions(),
      emotionKey: detail.expressionKey || 'SURPRISED',
      onEnd: () => { setActivity('idle'); responseEl.textContent = ''; },
    });
  });

  document.addEventListener('amic:battery-change', ({ detail }) => {
    const { level, charging } = detail;
    const bf = document.getElementById('hud-battery-fill');
    const chg = document.getElementById('hud-charging');
    bf.style.width      = level + '%';
    bf.style.background = level > 50 ? '#44aa66' : level > 20 ? '#aaaa44' : '#aa4444';
    chg.style.display   = charging ? 'inline' : 'none';
  });

  function spawnPop(delta, type) {
    const el = document.createElement('div');
    el.className = `stat-pop ${delta > 0 ? 'pos' : 'neg'}`;
    el.textContent = (delta > 0 ? '+' : '') + Math.round(delta);
    el.style.left = type === 'stamina' ? 'calc(50% + 30px)' : 'calc(50% - 30px)';
    document.body.appendChild(el);
    el.addEventListener('animationend', () => el.remove());
  }
  document.addEventListener('amic:stat-change', ({ detail }) => {
    if (detail.dEmotion) spawnPop(detail.dEmotion, 'emotion');
    if (detail.dStamina) spawnPop(detail.dStamina, 'stamina');
  });
  document.addEventListener('amic:learned', ({ detail }) => {
    const el = document.createElement('div');
    el.className = 'stat-pop learn';
    el.textContent = `+${detail.count} fato${detail.count > 1 ? 's' : ''}`;
    el.style.left = 'calc(50% + 60px)';
    document.body.appendChild(el);
    el.addEventListener('animationend', () => el.remove());
  });
  document.addEventListener('amic:learning', ({ detail }) => {
    statusLabel.textContent = `aprendendo sobre "${detail.topic}"...`;
    setActivity('think');
  });

  const _stageToast      = document.getElementById('stage-toast');
  const _stageToastEmoji = document.getElementById('stage-toast-emoji');
  const _stageToastName  = document.getElementById('stage-toast-name');
  let _stageToastTimer   = null;
  document.addEventListener('amic:stage-up', ({ detail }) => {
    const s = detail.stage;
    _stageToastEmoji.textContent = s.emoji;
    _stageToastName.textContent  = s.name;
    _stageToast.classList.add('show');
    clearTimeout(_stageToastTimer);
    _stageToastTimer = setTimeout(() => _stageToast.classList.remove('show'), 4500);
    playExpression('DELIGHTED');
  });

  // ── PTT (hold Space) ──────────────────────────────────────────────────────────
  let pttSession = null;
  document.addEventListener('keydown', async (e) => {
    if (e.code !== 'Space' || e.repeat || listening) return;
    if (['INPUT','TEXTAREA'].includes(document.activeElement?.tagName)) return;
    e.preventDefault();
    if (isSleeping()) { wakeUp(); return; }
    if (!loadMemory().apiKey) {
      statusLabel.textContent = 'Configure a chave da API primeiro (⚙)';
      setTimeout(() => (statusLabel.textContent = ''), 3000);
      return;
    }
    const mem = loadMemory();
    pttSession = listenPTT(mem.voiceLang || 'pt-BR');
    if (!pttSession) return;
    listening = true;
    pttSession.start();
    micBtn.classList.add('listening');
    statusLabel.textContent = 'Segure espaço para falar...';
    transcriptEl.textContent = '';
    responseEl.textContent = '';
    setActivity('listen');
  });
  document.addEventListener('keyup', async (e) => {
    if (e.code !== 'Space' || !pttSession) return;
    e.preventDefault();
    const text = await pttSession.stop();
    pttSession = null;
    micBtn.classList.remove('listening');
    if (!text?.trim()) { listening = false; statusLabel.textContent = ''; setActivity('idle'); return; }
    statusLabel.textContent = 'Pensando...';
    transcriptEl.textContent = `Você: ${text}`;
    setActivity('think');
    const r = getRobot();
    if (railsSessionId) saveMessage(railsSessionId, 'user', text, r.emotionPoints, r.stamina ?? 100).catch(() => {});
    const result = await handleUserMessage(text, {
      ...getVoiceOptions(),
      onChunk: (partial) => { responseEl.textContent = `Amic: ${partial}`; setActivity('speak'); },
      onEnd: () => setActivity('idle'),
    });
    if (result?.spokenText) {
      responseEl.textContent = `Amic: ${result.spokenText}`;
      if (railsSessionId) {
        const r2 = getRobot();
        saveMessage(railsSessionId, 'assistant', result.spokenText, r2.emotionPoints, r2.stamina ?? 100).catch(() => {});
      }
    } else if (result?.error) {
      responseEl.textContent = result.error;
      setActivity('idle');
    }
    statusLabel.textContent = '';
    listening = false;
  });

  // ── Settings panel ────────────────────────────────────────────────────────────
  const settingsBtn = document.getElementById('settings-btn');
  const panel       = document.getElementById('settings-panel');
  const overlay     = document.getElementById('settings-overlay');
  const closeBtn    = document.getElementById('panel-close');
  const toast       = document.getElementById('save-toast');

  function openPanel()  { populatePanel(); panel.classList.add('open'); overlay.classList.add('open'); settingsBtn.classList.add('open'); }
  function closePanel() { panel.classList.remove('open'); overlay.classList.remove('open'); settingsBtn.classList.remove('open'); }
  settingsBtn.addEventListener('click', () => panel.classList.contains('open') ? closePanel() : openPanel());
  closeBtn.addEventListener('click', closePanel);
  overlay.addEventListener('click', closePanel);

  function populatePanel() {
    const mem = loadMemory();
    document.getElementById('cfg-api-key').value  = mem.apiKey || '';
    document.getElementById('cfg-groq-key').value = mem.groqApiKey || '';
    document.getElementById('cfg-el-key').value   = mem.elevenLabsApiKey  || '';
    document.getElementById('cfg-el-voice').value = mem.elevenLabsVoiceId || '';
    document.getElementById('cfg-piper').checked  = mem.usePiperTts || false;
    document.getElementById('cfg-piper-voice').value = mem.piperVoice || 'pt_BR-faber-medium';
    document.getElementById('cfg-name').value     = mem.name || 'Amic';
    const skinSelect = document.getElementById('cfg-skin');
    if (!skinSelect.options.length) {
      for (const s of listSkins()) {
        const opt = document.createElement('option');
        opt.value = s.id;
        opt.textContent = s.name;
        skinSelect.appendChild(opt);
      }
    }
    skinSelect.value = mem.skinId || 'classic';
    document.getElementById('cfg-rate').value     = mem.voiceRate || 1;
    document.getElementById('cfg-rate-display').textContent = parseFloat(mem.voiceRate||1).toFixed(1)+'×';
    document.getElementById('cfg-debug').checked  = mem.showDebug || false;
    document.getElementById('cfg-lang').value     = mem.voiceLang || 'pt-BR';
    const lt = mem.memory?.long_term?.length ?? 0;
    const mt = mem.memory?.medium_term?.length ?? 0;
    const st = mem.memory?.short_term?.length ?? 0;
    document.getElementById('cfg-info').innerHTML =
      `Nascimento: ${new Date(mem.birthDate).toLocaleDateString('pt-BR')}<br>` +
      `Memória: ${lt} permanentes · ${mt} consolidadas · ${st} recentes<br>` +
      `Emoção: ${mem.emotionPoints ?? 50} pts · Stamina: ${mem.stamina ?? 100}/100`;
    const voiceSelect = document.getElementById('cfg-voice');
    voiceSelect.innerHTML = '<option value="">Padrão do sistema</option>';
    getAvailableVoices().then(voices => {
      voices.forEach(v => {
        const opt = document.createElement('option');
        opt.value = v.name; opt.textContent = `${v.name} (${v.lang})`;
        if (v.name === mem.voiceName) opt.selected = true;
        voiceSelect.appendChild(opt);
      });
    });
  }

  document.getElementById('cfg-rate').addEventListener('input', e => {
    document.getElementById('cfg-rate-display').textContent = parseFloat(e.target.value).toFixed(1)+'×';
  });
  document.getElementById('cfg-save').addEventListener('click', () => {
    const mem = loadMemory();
    mem.apiKey             = document.getElementById('cfg-api-key').value.trim();
    mem.groqApiKey         = document.getElementById('cfg-groq-key').value.trim();
    mem.elevenLabsApiKey   = document.getElementById('cfg-el-key').value.trim();
    mem.elevenLabsVoiceId  = document.getElementById('cfg-el-voice').value.trim();
    mem.usePiperTts        = document.getElementById('cfg-piper').checked;
    mem.piperVoice         = document.getElementById('cfg-piper-voice').value;
    mem.name               = document.getElementById('cfg-name').value.trim() || 'Amic';
    const newSkinId        = document.getElementById('cfg-skin').value;
    if (newSkinId !== mem.skinId) {
      statusLabel.textContent = 'Carregando skin...';
      setSkin(newSkinId)
        .then(() => { statusLabel.textContent = ''; })
        .catch(() => { statusLabel.textContent = 'Não consegui carregar essa skin.'; setTimeout(() => (statusLabel.textContent = ''), 3000); });
    }
    mem.skinId             = newSkinId;
    mem.voiceName          = document.getElementById('cfg-voice').value;
    mem.voiceRate          = parseFloat(document.getElementById('cfg-rate').value);
    mem.voiceLang          = document.getElementById('cfg-lang').value;
    mem.showDebug          = document.getElementById('cfg-debug').checked;
    saveMemory(mem);
    document.getElementById('robot-name').textContent = mem.name;
    document.title = mem.name;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2000);
  });
  document.getElementById('cfg-reset').addEventListener('click', () => {
    if (confirm('Tem certeza? O Amic vai perder toda a memória e renascer do zero.')) {
      resetMemory(); resetCodeLibrary();
      sessionStorage.removeItem('amic_session_id');
      location.reload();
    }
  });

  // ── Debug panel ───────────────────────────────────────────────────────────────
  function openDebug()  { debugPanel.classList.add('open'); debugBtn.classList.add('open'); updateDebugPanel(); }
  function closeDebug() { debugPanel.classList.remove('open'); debugBtn.classList.remove('open'); }
  debugBtn.addEventListener('click', () => debugPanel.classList.contains('open') ? closeDebug() : openDebug());
  debugClose.addEventListener('click', closeDebug);

  document.querySelectorAll('.acc-header').forEach(hdr => {
    hdr.addEventListener('click', () => hdr.closest('.acc-section').classList.toggle('open'));
  });

  function row(key, val) {
    return `<div class="dbg-row"><span class="dbg-key">${key}</span><span class="dbg-val">${val}</span></div>`;
  }
  function editRow(key, val, id, min, max) {
    return `<div class="dbg-row"><span class="dbg-key">${key}</span><span class="dbg-val">
      <span class="dbg-edit-wrap">
        <input class="dbg-edit-input" id="${id}" type="number" min="${min}" max="${max}" value="${val}">
        <button class="dbg-edit-btn" data-edit-target="${id}">✓</button>
      </span></span></div>`;
  }

  function updateDebugPanel() {
    if (!debugPanel?.classList.contains('open')) return;
    const robot = getRobot();
    const lib   = getCodeLibrary();
    const state = getEmotionState(robot.emotionPoints, robot.stamina ?? 100);
    const skills = robot.skills || {}, weak = robot.weaknesses || {};
    const stage = getRobotStage();
    document.getElementById('dbg-status').innerHTML = [
      row('Nome', robot.name||'Amic'),
      row('Nascimento', new Date(robot.birthDate).toLocaleDateString('pt-BR')),
      row('Estágio', `${stage.emoji} ${stage.name} (${stage.key})`),
      row('Estado emocional', `${state.name} (${state.key})`),
      editRow('Emoção', robot.emotionPoints??50, 'dbg-edit-emotion', 0, 100),
      editRow('Stamina', robot.stamina??100, 'dbg-edit-stamina', 0, 100),
      row('Minutos falados', robot.totalTalkMinutes??0),
      '<div class="dbg-tier">Habilidades</div>',
      ...Object.entries(skills).map(([k,v]) => row(k,v)),
      '<div class="dbg-tier">Fraquezas</div>',
      ...Object.entries(weak).map(([k,v]) => row(k,v)),
    ].join('');

    const mem = robot.memory || {};
    const lt = mem.long_term||[], mt = mem.medium_term||[], st = mem.short_term||[];
    let memHtml = '';
    if (lt.length) { memHtml += `<span class="dbg-tier">Permanentes (${lt.length})</span>`; memHtml += lt.map(f=>`<div class="dbg-fact">${escHtml(typeof f==='object'?(f.content||f.text||JSON.stringify(f)):f)}</div>`).join(''); }
    if (mt.length) { memHtml += `<span class="dbg-tier">Consolidadas (${mt.length})</span>`; memHtml += mt.map(f=>`<div class="dbg-fact">${escHtml(typeof f==='object'?(f.content||f.text||JSON.stringify(f)):f)}</div>`).join(''); }
    if (st.length) { memHtml += `<span class="dbg-tier">Recentes (${st.length})</span>`; memHtml += st.map(f=>`<div class="dbg-fact">${escHtml(typeof f==='object'?(f.content||f.text||JSON.stringify(f)):f)}</div>`).join(''); }
    if (!memHtml) memHtml = '<span class="dbg-empty">Nenhuma memória ainda.</span>';
    document.getElementById('dbg-memory').innerHTML = memHtml;

    const exprs = lib.expressions||{}, actions = lib.actions||{};
    let codeHtml = '';
    const actionEntries = Object.entries(actions);
    if (actionEntries.length) {
      codeHtml += `<span class="dbg-tier">Ações nomeadas (${actionEntries.length})</span>`;
      codeHtml += actionEntries.map(([name,{description,code,ts}]) => `
        <div class="dbg-code-item">
          <div class="dbg-code-name" onclick="this.closest('.dbg-code-item').classList.toggle('expanded')">
            ▶ ${escHtml(name)} <span style="opacity:0.55;font-size:0.58rem"> — ${escHtml(description||'')}</span>
            <span style="opacity:0.3;font-size:0.5rem"> ${ts?new Date(ts).toLocaleTimeString('pt-BR'):''}</span>
          </div>
          <pre class="dbg-code-detail">${escHtml(code)}</pre>
        </div>`).join('');
    }
    const exprEntries = Object.entries(exprs);
    if (exprEntries.length) {
      codeHtml += `<span class="dbg-tier">Expressões permanentes (${exprEntries.length})</span>`;
      codeHtml += exprEntries.map(([name,{params,ts}]) => `
        <div class="dbg-code-item">
          <div class="dbg-code-name" onclick="this.closest('.dbg-code-item').classList.toggle('expanded')">
            ▶ ${escHtml(name)} <span style="opacity:0.3;font-size:0.5rem">${ts?new Date(ts).toLocaleTimeString('pt-BR'):''}</span>
          </div>
          <pre class="dbg-code-detail">${escHtml(JSON.stringify(params,null,2))}</pre>
        </div>`).join('');
    }
    if (!codeHtml) codeHtml = '<span class="dbg-empty">Nenhum código aprendido ainda.</span>';
    document.getElementById('dbg-code').innerHTML = codeHtml;

    const history = (robot.conversationHistory||[]).slice(-10);
    document.getElementById('dbg-conv').innerHTML = history.length
      ? history.map(m=>`<div class="dbg-msg"><span class="dbg-role">${m.role==='user'?'Você':'Amic'}</span><div class="dbg-msg-text">${escHtml(m.content)}</div></div>`).join('')
      : '<span class="dbg-empty">Nenhuma conversa ainda.</span>';
  }

  // ── Log panel ─────────────────────────────────────────────────────────────────

  function renderLogs() {
    const list = document.getElementById('dbg-logs-list');
    if (!list) return;
    const entries = getLogs();
    if (!entries.length) {
      list.innerHTML = '<span class="dbg-empty">Nenhuma atividade ainda.</span>';
      return;
    }
    list.innerHTML = entries.map(e => {
      const time = new Date(e.ts).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      const badge = `<span class="log-badge log-badge-${e.level}">${e.level}</span>`;
      const model = e.model ? `<span class="log-model">${escHtml(e.model)}</span>` : '';
      const detailsStr = e.details
        ? (typeof e.details === 'string' ? e.details : JSON.stringify(e.details, null, 2))
        : '';
      const detailsEl = detailsStr
        ? `<div class="log-details" title="clique para expandir">${escHtml(detailsStr)}</div>`
        : '';
      return `<div class="log-entry" ${detailsStr ? 'onclick="this.classList.toggle(\'expanded\')"' : ''}>
        <div class="log-meta">
          <span class="log-time">${time}</span>
          ${badge}
          <span class="log-action">${escHtml(e.action)}</span>
          ${model}
        </div>
        ${e.message ? `<div class="log-msg">${escHtml(e.message)}</div>` : ''}
        ${detailsEl}
      </div>`;
    }).join('');
  }

  document.getElementById('dbg-logs-clear').addEventListener('click', () => {
    clearLogs(); renderLogs();
  });

  document.addEventListener('amic:log', () => {
    if (document.getElementById('acc-logs')?.classList.contains('open')) renderLogs();
  });

  document.getElementById('acc-logs').querySelector('.acc-header').addEventListener('click', renderLogs);

  document.getElementById('dbg-status').addEventListener('click', (e) => {
    const btn = e.target.closest('.dbg-edit-btn');
    if (!btn) return;
    const input = document.getElementById(btn.dataset.editTarget);
    if (!input) return;
    const val = Math.max(parseInt(input.min), Math.min(parseInt(input.max), parseInt(input.value)||0));
    const r = getRobot();
    if (btn.dataset.editTarget === 'dbg-edit-emotion') r.emotionPoints = val;
    if (btn.dataset.editTarget === 'dbg-edit-stamina') r.stamina = val;
    setRobot(r); updateUI(r); updateDebugPanel();
  });
  document.getElementById('dbg-status').addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    e.target.closest('.dbg-edit-wrap')?.querySelector('.dbg-edit-btn')?.click();
  });

  function escHtml(s) {
    return String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  document.addEventListener('amic:code-executed', () => {
    setActivity('code');
    setTimeout(() => setActivity('idle'), 1800);
    updateDebugPanel();
  });

  // ── Vision / Camera ───────────────────────────────────────────────────────────
  const visionOverlay    = document.getElementById('vision-overlay');
  const visionVideo      = document.getElementById('vision-video');
  const visionCanvas     = document.getElementById('vision-canvas');
  const visionStatus     = document.getElementById('vision-status');
  const visionCaptureBtn = document.getElementById('vision-capture-btn');
  const visionCloseBtn   = document.getElementById('vision-close-btn');
  const visionProc       = document.getElementById('vision-proc');
  const visionProcEmoji  = document.getElementById('vision-proc-emoji');
  const camBtn           = document.getElementById('cam-btn');
  const camFaceCount     = document.getElementById('cam-face-count');

  let _cameraStream      = null;
  let _knownProfiles     = [];
  let _pendingNewFace    = null;   // face data awaiting a name via mic
  let _awaitingFaceName  = false;  // mic input intercepted to save a face name
  let _procSoundTimer    = null;   // scanning sound loop handle

  async function _loadFaceProfiles() {
    try {
      const res = await fetch('/api/face_profiles', { credentials: 'same-origin' });
      if (res.ok) _knownProfiles = await res.json();
    } catch {}
  }

  // Position the processing indicator near Amic's head on the canvas
  function _positionProcIndicator() {
    const rect = canvas.getBoundingClientRect();
    const cx = rect.left + rect.width * 0.62;
    const cy = rect.top  + rect.height * 0.18;
    visionProc.style.left = `${cx}px`;
    visionProc.style.top  = `${cy}px`;
  }

  const PROC_EMOJIS = ['🔍','👁️','🧠','🔎','✨','💫'];
  let _procEmojiIdx = 0;

  function _startProcIndicator() {
    _positionProcIndicator();
    visionProc.classList.add('active');
    visionProcEmoji.textContent = PROC_EMOJIS[0];
    _procEmojiIdx = 0;
    // Cycle emojis and play scanning tones every ~600ms
    _procSoundTimer = setInterval(() => {
      _procEmojiIdx = (_procEmojiIdx + 1) % PROC_EMOJIS.length;
      visionProcEmoji.textContent = PROC_EMOJIS[_procEmojiIdx];
      // Short scanning beep sequence
      _tone('sine',  880, 1200, 0.08, 0.032, 0.00);
      _tone('sine', 1200,  880, 0.08, 0.020, 0.10);
    }, 600);
    // Initial scan sound burst
    _tone('square', 440, 660, 0.12, 0.025, 0.00);
    _tone('square', 660, 880, 0.10, 0.022, 0.14);
    _tone('sine',  1100, 800, 0.15, 0.030, 0.28);
  }

  function _stopProcIndicator() {
    if (_procSoundTimer) { clearInterval(_procSoundTimer); _procSoundTimer = null; }
    visionProc.classList.remove('active');
    // Done sound — ascending chime
    _tone('sine', 660,  880, 0.12, 0.035, 0.00);
    _tone('sine', 880, 1100, 0.10, 0.030, 0.13);
    _tone('sine',1100, 1320, 0.10, 0.028, 0.24);
  }

  async function openVision() {
    await _loadFaceProfiles();
    visionOverlay.classList.add('open');
    visionCaptureBtn.disabled = true;
    visionStatus.textContent  = 'Iniciando câmera...';
    try {
      _cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 640 } });
      visionVideo.srcObject = _cameraStream;
      await new Promise(r => visionVideo.addEventListener('loadedmetadata', r, { once: true }));
      visionCaptureBtn.disabled = false;
      visionStatus.textContent  = 'Pronto — clique em Capturar.';
    } catch (e) {
      visionStatus.textContent = 'Câmera não disponível: ' + (e.message || e);
    }
  }

  function _closeVision() {
    visionOverlay.classList.remove('open');
    if (_cameraStream) { _cameraStream.getTracks().forEach(t => t.stop()); _cameraStream = null; }
    _stopProcIndicator();
  }

  async function _captureAndAnalyze() {
    visionCaptureBtn.disabled = true;
    visionStatus.textContent  = 'Analisando...';
    setActivity('think');
    _startProcIndicator();

    visionCanvas.width  = visionVideo.videoWidth;
    visionCanvas.height = visionVideo.videoHeight;
    const ctx = visionCanvas.getContext('2d');
    ctx.translate(visionCanvas.width, 0);
    ctx.scale(-1, 1);
    ctx.drawImage(visionVideo, 0, 0);
    ctx.setTransform(1, 0, 0, 1, 0, 0);

    let faces;
    try {
      faces = await analyzeFrame(visionCanvas);
    } catch (e) {
      _stopProcIndicator();
      visionStatus.textContent  = e.message;
      visionCaptureBtn.disabled = false;
      setActivity('idle');
      return;
    }

    _stopProcIndicator();

    if (!faces.length) {
      visionStatus.textContent  = 'Nenhum rosto encontrado. Tente de novo.';
      visionCaptureBtn.disabled = false;
      setActivity('idle');
      _tone('triangle', 380, 200, 0.25, 0.04);
      return;
    }

    const results = faces.map(f => ({
      ...f,
      match: findBestMatch(f.descriptor, _knownProfiles),
    }));

    // Update last_seen for recognized faces
    const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
    for (const r of results) {
      if (r.match) {
        fetch(`/api/face_profiles/${r.match.profile.id}`, {
          method: 'PATCH', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
          body: JSON.stringify({})
        }).catch(() => {});
      }
    }

    _closeVision();

    const unknown = results.filter(r => !r.match);
    const known   = results.filter(r =>  r.match);

    camFaceCount.textContent   = results.length;
    camFaceCount.style.display = 'flex';
    setTimeout(() => { camFaceCount.style.display = 'none'; }, 6000);

    // Apply mood boost for seeing a known face
    if (known.length > 0) setRobot(applyEvent(getRobot(), 'face_seen'));

    // Build vision context message and let Amic react naturally
    const visionParts = results.map(r => {
      if (r.match) return `reconheci ${r.match.profile.nickname}`;
      const g = r.gender === 'male' ? 'homem' : 'mulher';
      return `pessoa desconhecida (${g}, aprox. ${r.age} anos)`;
    });
    const visionMsg = `[VISAO_CAMERA: ${visionParts.join(', ')}]`;

    const visionResult = await handleUserMessage(visionMsg, {
      ...getVoiceOptions(),
      onChunk: (partial) => { responseEl.textContent = `Amic: ${partial}`; setActivity('speak'); },
      onEnd:   () => setActivity('idle'),
    });
    if (visionResult?.spokenText) responseEl.textContent = `Amic: ${visionResult.spokenText}`;
    statusLabel.textContent = '';

    // Unknown face(s) — Amic asks for the name, mic intercepts the answer
    if (unknown.length >= 1) {
      _pendingNewFace   = unknown[0];
      _awaitingFaceName = true;
      const askText = unknown.length === 1
        ? 'Não conheço essa pessoa. Qual é o nome dela?'
        : `Tem ${unknown.length} pessoas que não conheço. Como se chama a primeira?`;
      responseEl.textContent = `Amic: ${askText}`;
      playExpression('CURIOUS');
      speak(askText, {
        ...getVoiceOptions(), emotionKey: 'CURIOUS',
        onEnd: () => { statusLabel.textContent = '🎤 Diga o nome...'; setActivity('listen'); },
      });
    }
  }

  async function _saveNewFace(nickname) {
    if (!_pendingNewFace || !nickname.trim()) return;
    const face        = _pendingNewFace;
    _pendingNewFace   = null;
    _awaitingFaceName = false;
    statusLabel.textContent = '';
    setActivity('think');

    try {
      const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
      const res  = await fetch('/api/face_profiles', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
        body: JSON.stringify({
          nickname:        nickname.trim(),
          descriptor:      face.descriptor,
          characteristics: { age: face.age, gender: face.gender }
        })
      });
      if (res.ok) {
        const saved = await res.json();
        _knownProfiles.push(saved);
        const greeting = `Prazer em te conhecer, ${nickname.trim()}! Vou lembrar de você.`;
        responseEl.textContent = `Amic: ${greeting}`;
        playExpression('DELIGHTED');
        speak(greeting, {
          ...getVoiceOptions(), emotionKey: 'DELIGHTED',
          onEnd: () => { setActivity('idle'); setTimeout(() => { responseEl.textContent = ''; }, 3000); },
        });
      }
    } catch (e) {
      console.error('Erro ao salvar rosto:', e);
    }
  }

  camBtn.addEventListener('click', openVision);
  visionCloseBtn.addEventListener('click', _closeVision);
  visionCaptureBtn.addEventListener('click', _captureAndAnalyze);

  // Amic can also request vision via event (e.g. from robot.js)
  document.addEventListener('amic:vision-request', openVision);
</script>
