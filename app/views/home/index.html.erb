<% content_for :title, "Amic" %>
<% content_for :head do %>
<style>
  :root {
    --bg: #0d0d0f;
    --surface: #16161a;
    --surface2: #1e1e24;
    --face-color: #e0e0ff;
    --accent: #7c6af5;
    --text-muted: #555566;
    --text: #ccccdd;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Courier New', monospace;
    height: 100dvh;
    overflow: hidden;
  }

  /* Full-screen canvas */
  #face-wrap {
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100dvh;
    z-index: 0;
  }
  #bip-face {
    display: block;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  /* Top bar */
  #user-chip {
    position: fixed;
    top: 14px; left: 14px;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    z-index: 10;
    pointer-events: none;
  }
  #robot-name {
    position: fixed;
    top: 14px; left: 50%;
    transform: translateX(-50%);
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    color: var(--text-muted);
    text-transform: uppercase;
    z-index: 10;
    pointer-events: none;
  }

  /* Bottom gradient overlay — houses all bottom UI */
  #bottom-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    padding: 12px 16px 20px;
    background: linear-gradient(to top, rgba(13,13,15,0.88) 0%, rgba(13,13,15,0.40) 60%, transparent 100%);
    display: flex;
    align-items: flex-end;
    gap: 10px;
    z-index: 10;
  }

  /* Left: HUD bars + emotion label */
  #left-hud {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
    pointer-events: none;
  }

  .emotion-label {
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: color 0.5s;
  }
  .emotion-euphoric  { color: #f5c842; }
  .emotion-happy     { color: #7c6af5; }
  .emotion-neutral   { color: var(--text-muted); }
  .emotion-sad       { color: #5588bb; }
  .emotion-grumpy    { color: #bb5555; }
  .emotion-tired     { color: #889988; }
  .emotion-exhausted { color: #667766; }

  #points-label { display: none; font-size: 0.55rem; color: var(--text-muted); }

  #mood-hud  { display: flex; gap: 8px; align-items: flex-end; }
  .hud-col   { display: flex; flex-direction: column; align-items: center; gap: 3px; }
  .hud-bar   { width: 48px; height: 3px; background: #1e1e24; border-radius: 2px; overflow: hidden; }
  .hud-fill  { height: 100%; width: 0%; transition: width 0.5s, background 0.5s; border-radius: 2px; }
  .hud-lbl   { font-size: 0.38rem; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase; }
  #hud-charging { font-size: 0.6rem; color: #44aa66; display: none; margin-bottom: 1px;
                  animation: blink-charge 1.2s infinite; align-self: flex-end; }
  @keyframes blink-charge { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* Center: status + conversation */
  #center-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    pointer-events: none;
  }

  #status-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    min-height: 1em;
    letter-spacing: 0.1em;
  }

  #conversation {
    background: rgba(22, 22, 26, 0.70);
    backdrop-filter: blur(6px);
    border-radius: 10px;
    padding: 8px 11px;
    pointer-events: none;
  }
  #transcript { font-size: 0.65rem; color: var(--text-muted); min-height: 1em; }
  #response   { font-size: 0.75rem; color: var(--text); margin-top: 3px; min-height: 1em; line-height: 1.5; }

  #text-input {
    pointer-events: auto;
    background: rgba(22, 22, 26, 0.70);
    backdrop-filter: blur(6px);
    border: 1px solid #333344;
    border-radius: 10px;
    padding: 8px 11px;
    font-family: 'Courier New', monospace;
    font-size: 0.72rem;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }
  #text-input::placeholder { color: var(--text-muted); }
  #text-input:focus { border-color: var(--accent); }
  #text-input:disabled { opacity: 0.5; }

  /* Mic button — right of bottom bar */
  #mic-btn {
    flex-shrink: 0;
    width: 58px; height: 58px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: rgba(13,13,15,0.6);
    backdrop-filter: blur(6px);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, box-shadow 0.2s;
    pointer-events: auto;
  }
  #mic-btn:hover { background: rgba(124,106,245,0.18); }
  #mic-btn.listening { background: rgba(124,106,245,0.28); animation: pulse 1.2s infinite; }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 rgba(124,106,245,0.5); }
    70%  { box-shadow: 0 0 0 18px rgba(124,106,245,0); }
    100% { box-shadow: 0 0 0 0 rgba(124,106,245,0); }
  }
  #mic-btn svg { width: 25px; height: 25px; stroke: var(--accent); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  /* Stat pop-ups */
  .stat-pop { position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%);
    font-size: 0.75rem; font-family: 'Courier New', monospace; pointer-events: none;
    animation: float-up 1.4s ease-out forwards; z-index: 20; }
  .stat-pop.pos   { color: #44aa66; }
  .stat-pop.neg   { color: #aa4444; }
  .stat-pop.learn { color: #7c6af5; }
  @keyframes float-up {
    0%   { opacity: 1; transform: translateX(-50%) translateY(0); }
    100% { opacity: 0; transform: translateX(-50%) translateY(-44px); }
  }

  /* Top-right nav */
  .top-nav { position: fixed; top: 14px; right: 14px; display: flex; gap: 6px; z-index: 20; }
  .nav-btn {
    width: 34px; height: 34px;
    border: none; background: transparent;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    opacity: 0.35; transition: opacity 0.2s, transform 0.3s;
    text-decoration: none;
  }
  .nav-btn:hover { opacity: 1; }
  .nav-btn.open  { opacity: 1; transform: rotate(90deg); }
  .nav-btn svg   { width: 19px; height: 19px; stroke: var(--text); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  /* Camera button */
  #cam-btn {
    flex-shrink: 0;
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 1px solid #333344;
    background: rgba(13,13,15,0.55);
    backdrop-filter: blur(6px);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    opacity: 0.6; transition: opacity 0.2s, border-color 0.2s;
    pointer-events: auto;
  }
  #cam-btn:hover { opacity: 1; border-color: var(--accent); }
  #cam-btn svg { width: 20px; height: 20px; stroke: var(--text); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

  /* Vision overlay */
  #vision-overlay {
    display: none;
    position: fixed; inset: 0; z-index: 150;
    background: rgba(13,13,15,0.92);
    flex-direction: column; align-items: center; justify-content: center;
    gap: 14px;
  }
  #vision-overlay.open { display: flex; }
  #vision-video {
    width: min(480px, 92vw); height: auto;
    border-radius: 14px; border: 1px solid #333344;
    background: #000; transform: scaleX(-1); /* mirror */
  }
  #vision-canvas { display: none; }
  #vision-status {
    font-size: 0.72rem; color: var(--text-muted); letter-spacing: 0.1em;
    min-height: 1.2em; text-align: center;
  }
  #vision-controls { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; justify-content: center; }
  #vision-capture-btn {
    padding: 10px 24px; background: var(--accent); border: none; border-radius: 8px;
    color: #fff; font-family: 'Courier New', monospace; font-size: 0.72rem;
    letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer;
    transition: background 0.2s;
  }
  #vision-capture-btn:hover { background: #6a59e0; }
  #vision-capture-btn:disabled { opacity: 0.4; cursor: default; }
  #vision-close-btn {
    padding: 10px 16px; background: transparent; border: 1px solid #333344; border-radius: 8px;
    color: var(--text-muted); font-family: 'Courier New', monospace; font-size: 0.72rem;
    cursor: pointer; transition: color 0.2s;
  }
  #vision-close-btn:hover { color: var(--text); }


  /* Face count badge on camera button */
  #cam-face-count {
    position: absolute; top: -4px; right: -4px;
    background: var(--accent); color: #fff;
    font-size: 0.55rem; font-family: 'Courier New', monospace;
    width: 16px; height: 16px; border-radius: 50%;
    display: none; align-items: center; justify-content: center;
  }
  #cam-btn { position: relative; }

  /* Settings panel */
  #settings-panel {
    position: fixed; top: 0; right: 0;
    height: 100dvh; width: min(340px, 90vw);
    background: var(--surface);
    border-left: 1px solid #222230;
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    z-index: 100; overflow-y: auto;
  }
  #settings-panel.open { transform: translateX(0); }

  .panel-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 20px 16px; border-bottom: 1px solid #222230; }
  .panel-header h2 { font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--text-muted); }
  #panel-close { background: transparent; border: none; cursor: pointer; color: var(--text-muted); font-size: 1.1rem; padding: 4px; transition: color 0.2s; }
  #panel-close:hover { color: var(--text); }

  .panel-section { padding: 14px 20px; border-bottom: 1px solid #1a1a22; display: flex; flex-direction: column; gap: 8px; }
  .panel-label { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); }
  .panel-hint  { font-size: 0.62rem; color: var(--text-muted); opacity: 0.7; }
  .panel-row   { display: flex; align-items: center; justify-content: space-between; }

  .panel-input, .panel-select {
    background: var(--surface2); border: 1px solid #2a2a35; border-radius: 8px;
    padding: 10px 12px; color: var(--text);
    font-family: 'Courier New', monospace; font-size: 0.8rem;
    width: 100%; outline: none; transition: border-color 0.2s;
  }
  .panel-input:focus { border-color: var(--accent); }
  .panel-range { width: 100%; accent-color: var(--accent); }

  .toggle { position: relative; width: 40px; height: 22px; }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-track { position: absolute; inset: 0; background: #2a2a35; border-radius: 11px; cursor: pointer; transition: background 0.2s; }
  .toggle input:checked + .toggle-track { background: var(--accent); }
  .toggle-track::after { content: ''; position: absolute; top: 3px; left: 3px; width: 16px; height: 16px; background: white; border-radius: 50%; transition: transform 0.2s; }
  .toggle input:checked + .toggle-track::after { transform: translateX(18px); }

  .btn-save {
    margin: 16px 20px; padding: 11px;
    background: var(--accent); border: none; border-radius: 8px;
    color: white; font-family: 'Courier New', monospace;
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    cursor: pointer; transition: background 0.2s;
  }
  .btn-save:hover { background: #6a59e0; }

  .btn-reset {
    margin: 0 20px 20px; padding: 10px;
    background: transparent; border: 1px solid #4a1a1a; border-radius: 8px;
    color: #bb5555; font-family: 'Courier New', monospace;
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    cursor: pointer; transition: background 0.2s;
  }
  .btn-reset:hover { background: #1a0a0a; }

  .panel-info { margin: 0 20px 16px; padding: 12px; background: var(--surface2); border-radius: 8px; font-size: 0.6rem; color: var(--text-muted); line-height: 1.8; }

  #settings-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 99; }
  #settings-overlay.open { display: block; }

  /* Debug panel */
  #debug-panel {
    position: fixed; top: 0; left: 0;
    height: 100dvh; width: min(380px, 95vw);
    background: var(--surface);
    border-right: 1px solid #222230;
    display: flex; flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    z-index: 100; overflow-y: auto;
    font-size: 0.72rem;
  }
  #debug-panel.open { transform: translateX(0); }
  #debug-btn.open { opacity: 1; }

  .acc-section { border-bottom: 1px solid #1a1a22; }
  .acc-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px; cursor: pointer; user-select: none;
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-muted); transition: color 0.2s;
  }
  .acc-header:hover { color: var(--text); }
  .acc-header .acc-arrow { transition: transform 0.2s; font-size: 0.5rem; }
  .acc-section.open .acc-header .acc-arrow { transform: rotate(90deg); }
  .acc-body { display: none; padding: 6px 16px 12px; }
  .acc-section.open .acc-body { display: block; }

  .dbg-row { display: flex; justify-content: space-between; align-items: baseline;
    padding: 3px 0; border-bottom: 1px solid #16161a; }
  .dbg-row:last-child { border-bottom: none; }
  .dbg-key { color: var(--text-muted); font-size: 0.62rem; }
  .dbg-val { color: var(--text); font-size: 0.68rem; text-align: right; max-width: 55%; word-break: break-all; }

  .dbg-fact { padding: 4px 0; border-bottom: 1px solid #16161a; color: var(--text); font-size: 0.65rem; line-height: 1.4; }
  .dbg-fact:last-child { border-bottom: none; }
  .dbg-tier { font-size: 0.5rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--accent); opacity: 0.6; display: block; margin-bottom: 4px; margin-top: 8px; }

  .dbg-code-item { margin-bottom: 10px; }
  .dbg-code-name { font-size: 0.6rem; color: var(--accent); letter-spacing: 0.15em; margin-bottom: 4px; cursor: pointer; }
  .dbg-code-name:hover { opacity: 0.7; }
  .dbg-code-detail { display: none; background: #0d0d0f; border-radius: 4px;
    padding: 6px 8px; font-size: 0.58rem; color: var(--text-muted); white-space: pre-wrap; line-height: 1.5; }
  .dbg-code-item.expanded .dbg-code-detail { display: block; }

  .dbg-msg { padding: 4px 0; border-bottom: 1px solid #16161a; font-size: 0.65rem; line-height: 1.4; }
  .dbg-msg:last-child { border-bottom: none; }
  .dbg-msg .dbg-role { font-size: 0.5rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent); opacity: 0.7; }
  .dbg-msg .dbg-msg-text { color: var(--text); margin-top: 2px; }
  .dbg-empty { color: var(--text-muted); font-size: 0.62rem; font-style: italic; }

  .log-entry { padding: 5px 0; border-bottom: 1px solid #16161a; font-size: 0.63rem; line-height: 1.4; }
  .log-entry:last-child { border-bottom: none; }
  .log-entry .log-meta { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .log-entry .log-time { color: var(--text-muted); font-size: 0.55rem; font-variant-numeric: tabular-nums; }
  .log-badge { font-size: 0.48rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 1px 5px; border-radius: 3px; font-weight: 600; }
  .log-badge-info  { background: #1a2a1a; color: #4caf50; }
  .log-badge-warn  { background: #2a2200; color: #ffc107; }
  .log-badge-error { background: #2a1010; color: #ef5350; }
  .log-entry .log-action { color: var(--accent); font-size: 0.6rem; }
  .log-entry .log-model  { color: var(--text-muted); font-size: 0.55rem; font-style: italic; }
  .log-entry .log-msg    { color: var(--text); margin-top: 2px; word-break: break-all; }
  .log-entry .log-details { margin-top: 3px; background: #0d0d0f; border-radius: 3px; padding: 4px 6px;
    font-size: 0.58rem; color: #a0a0b0; white-space: pre-wrap; display: none; cursor: pointer; }
  .log-entry.expanded .log-details { display: block; }

  .dbg-edit-wrap { display: flex; align-items: center; gap: 5px; }
  .dbg-edit-input {
    width: 48px; background: var(--surface2);
    border: 1px solid #2a2a35; border-radius: 4px;
    color: var(--text); padding: 2px 5px;
    font-family: 'Courier New', monospace; font-size: 0.65rem;
    text-align: right;
  }
  .dbg-edit-input:focus { border-color: var(--accent); outline: none; }
  .dbg-edit-btn {
    background: transparent; border: 1px solid #2a2a35; border-radius: 4px;
    color: var(--accent); cursor: pointer; font-size: 0.6rem;
    padding: 2px 5px; transition: background 0.15s;
  }
  .dbg-edit-btn:hover { background: rgba(124,106,245,0.15); }

  #save-toast {
    position: fixed; bottom: 32px; left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--accent); color: white;
    font-size: 0.75rem; padding: 10px 24px; border-radius: 999px;
    opacity: 0; transition: opacity 0.25s, transform 0.25s;
    pointer-events: none; z-index: 200;
  }
  #save-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* Sleep effects */
  #sleep-fx {
    position: fixed; top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none; z-index: 10;
  }
  .zzz-particle {
    position: absolute;
    font-family: 'Courier New', monospace;
    color: var(--accent);
    pointer-events: none; opacity: 0;
    animation: zzz-rise var(--dur, 2.8s) ease-out forwards;
  }
  @keyframes zzz-rise {
    0%   { opacity: 0;    transform: translateY(0px)   scale(0.6); }
    18%  { opacity: 0.9;  transform: translateY(-12px) scale(1.0); }
    75%  { opacity: 0.7; }
    100% { opacity: 0;    transform: translateY(-70px) scale(1.1); }
  }
  .dream-bubble {
    position: absolute;
    background: rgba(22, 22, 26, 0.92);
    border: 1px solid rgba(124, 106, 245, 0.35);
    border-radius: 50%;
    width: 46px; height: 46px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem;
    pointer-events: none; opacity: 0;
    animation: bubble-float var(--dur, 4.5s) ease-out forwards;
    box-shadow: 0 0 12px rgba(124, 106, 245, 0.15);
  }
  @keyframes bubble-float {
    0%   { opacity: 0; transform: translateY(0)    scale(0.4); }
    20%  { opacity: 1; transform: translateY(-22px) scale(1.0); }
    75%  { opacity: 0.85; }
    100% { opacity: 0; transform: translateY(-95px) scale(0.75); }
  }

  /* Vision processing indicator */
  #vision-proc {
    display: none;
    position: fixed; z-index: 160;
    pointer-events: none;
    flex-direction: column; align-items: center; gap: 6px;
  }
  #vision-proc.active { display: flex; }
  #vision-proc-emoji {
    font-size: 2rem;
    animation: proc-pulse 0.6s ease-in-out infinite alternate;
    filter: drop-shadow(0 0 8px rgba(124,106,245,0.7));
  }
  #vision-proc-bar {
    width: 48px; height: 3px;
    background: #1e1e24; border-radius: 2px; overflow: hidden;
  }
  #vision-proc-fill {
    height: 100%; width: 0%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.18s linear;
    animation: proc-scan 1.1s ease-in-out infinite;
  }
  @keyframes proc-pulse {
    from { transform: scale(0.9); opacity: 0.7; }
    to   { transform: scale(1.1); opacity: 1.0; }
  }
  @keyframes proc-scan {
    0%   { margin-left: 0%;   width: 30%; }
    50%  { margin-left: 70%;  width: 30%; }
    100% { margin-left: 0%;   width: 30%; }
  }

  /* Stage-up toast */
  #stage-toast {
    position: fixed; top: 60px; left: 50%;
    transform: translateX(-50%) translateY(-20px);
    background: var(--surface);
    border: 1px solid var(--accent);
    border-radius: 12px;
    padding: 12px 22px;
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    opacity: 0; transition: opacity 0.35s, transform 0.35s;
    pointer-events: none; z-index: 200;
    text-align: center;
  }
  #stage-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  #stage-toast-emoji { font-size: 1.5rem; }
  #stage-toast-title { font-size: 0.62rem; color: var(--accent); letter-spacing: 0.2em; text-transform: uppercase; }
  #stage-toast-name  { font-size: 0.8rem; color: var(--text); }

  /* Onboarding overlay */
  #onboarding {
    position: fixed; inset: 0; z-index: 300;
    background: var(--bg);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 18px;
    padding: 24px;
    transition: opacity 0.6s;
  }
  #onboarding.hidden { opacity: 0; pointer-events: none; }
  #onboarding.gone   { display: none; }
  #ob-bubble {
    background: rgba(22,22,26,0.92);
    border: 1px solid rgba(124,106,245,0.35);
    border-radius: 18px;
    padding: 16px 22px;
    font-size: 0.9rem;
    color: var(--text);
    max-width: 320px;
    text-align: center;
    line-height: 1.6;
    min-height: 3em;
    transition: opacity 0.4s;
  }
  #ob-name-form {
    display: none;
    flex-direction: column; align-items: center; gap: 10px;
  }
  #ob-name-form.show { display: flex; }
  #ob-name-input {
    background: var(--surface2); border: 1px solid var(--accent);
    border-radius: 10px; padding: 11px 16px;
    color: var(--text); font-family: 'Courier New', monospace;
    font-size: 0.85rem; text-align: center; outline: none;
    width: 200px;
  }
  #ob-name-input::placeholder { color: var(--text-muted); }
  #ob-confirm-btn {
    padding: 10px 28px;
    background: var(--accent); border: none; border-radius: 8px;
    color: #fff; font-family: 'Courier New', monospace;
    font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase;
    cursor: pointer; transition: background 0.2s;
  }
  #ob-confirm-btn:hover { background: #6a59e0; }
  #ob-skip {
    font-size: 0.58rem; color: var(--text-muted); letter-spacing: 0.15em;
    text-transform: uppercase; cursor: pointer; opacity: 0.5;
    text-decoration: underline; border: none; background: transparent;
  }
  #ob-skip:hover { opacity: 1; }

  /* Touch ripple feedback */
  .touch-ripple {
    position: fixed; pointer-events: none; z-index: 15;
    width: 40px; height: 40px; margin-left: -20px; margin-top: -20px;
    border-radius: 50%; border: 2px solid rgba(124,106,245,0.6);
    animation: ripple-out 0.5s ease-out forwards;
  }
  @keyframes ripple-out {
    0%   { transform: scale(0.3); opacity: 0.9; }
    100% { transform: scale(2.0); opacity: 0;   }
  }
</style>
<% end %>

