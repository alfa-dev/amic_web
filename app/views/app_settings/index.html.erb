<% content_for :title, "Configurações do servidor — Amic" %>
<% content_for :head do %>
<style>
  :root { --bg:#0d0d0f; --surface:#16161a; --surface2:#1e1e24; --accent:#7c6af5; --text:#ccccdd; --text-muted:#555566; }
  * { box-sizing:border-box; margin:0; padding:0; }
  body { background:var(--bg); color:var(--text); font-family:'Courier New',monospace; min-height:100dvh; padding:32px 16px; }

  .top-bar { display:flex; align-items:center; gap:16px; margin-bottom:32px; max-width:520px; margin-left:auto; margin-right:auto; }
  .back-link { color:var(--text-muted); text-decoration:none; font-size:0.8rem; transition:color 0.2s; }
  .back-link:hover { color:var(--text); }
  h1 { font-size:0.8rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--text-muted); }

  .card { max-width:520px; margin:0 auto; background:var(--surface); border-radius:14px; padding:24px; display:flex; flex-direction:column; gap:16px; }

  .field { display:flex; flex-direction:column; gap:8px; }
  label { font-size:0.65rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--text-muted); }
  input[type=password] {
    background:var(--surface2); border:1px solid #2a2a35; border-radius:8px;
    padding:11px 14px; color:var(--text); font-family:'Courier New',monospace;
    font-size:0.82rem; outline:none; transition:border-color 0.2s;
  }
  input[type=password]:focus { border-color:var(--accent); }
  .hint { font-size:0.62rem; color:var(--text-muted); }

  .btn {
    padding:12px; background:var(--accent); border:none; border-radius:8px;
    color:white; font-family:'Courier New',monospace; font-size:0.75rem;
    letter-spacing:0.15em; text-transform:uppercase; cursor:pointer; transition:background 0.2s;
  }
  .btn:hover { background:#6a59e0; }

  .notice { background:#1a2a1a; border:1px solid #2a4a2a; border-radius:8px; padding:12px 16px; font-size:0.75rem; color:#88bb88; }

  .info { font-size:0.7rem; color:var(--text-muted); line-height:1.8; background:var(--surface2); border-radius:8px; padding:14px; }
</style>
<% end %>

<div class="top-bar">
  <%= link_to '← histórico', '/history', class: 'back-link' %>
  <h1>Configurações do servidor</h1>
</div>

<div class="card">
  <% if notice %>
    <div class="notice"><%= notice %></div>
  <% end %>

  <%= form_with url: '/app_settings', method: :patch do |f| %>
    <div class="field">
      <label for="api_key">Chave da API Claude (servidor)</label>
      <input type="password" id="api_key" name="api_key" value="<%= @api_key %>" placeholder="sk-ant-..." autocomplete="off" />
      <span class="hint">Usada para análise de conversas. Fica salva no banco de dados do servidor.</span>
    </div>
    <button type="submit" class="btn">Salvar</button>
  <% end %>

  <div class="info">
    Esta chave é usada exclusivamente para a funcionalidade de análise de conversas.<br>
    A chave que o Amic usa para conversar fica no <strong>localStorage do navegador</strong> e é configurada no painel de engrenagem da tela principal.
  </div>
</div>
